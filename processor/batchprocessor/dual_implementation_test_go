// TestBothImplementations tests that both legacy and exporterhelper implementations work
func TestBothImplementations(t *testing.T) {
	TestWithFeatureGates(t, "ProcessorCreation", func(t *testing.T, useExporterHelper bool) {
		factory := NewFactory()
		cfg := factory.CreateDefaultConfig().(*Config)

		// Verify the implementation being used
		requireImplementation(t, cfg, useExporterHelper)

		// Test processor creation
		ctx := context.Background()
		creationSet := processortest.NewNopSettings(factory.Type())
		sink := &consumertest.TracesSink{}

		// Create traces processor
		tp, err := factory.CreateTraces(ctx, creationSet, cfg, sink)
		require.NoError(t, err)
		require.NotNil(t, tp)

		// Start the processor
		require.NoError(t, tp.Start(ctx, componenttest.NewNopHost()))

		// Send some test data
		td := testdata.GenerateTraces(2)
		err = tp.ConsumeTraces(ctx, td)
		require.NoError(t, err)

		// Give it time to process
		assert.Eventually(t, func() bool {
			return sink.SpanCount() > 0
		}, 5*time.Second, 10*time.Millisecond)

		// Verify data was processed
		assert.Equal(t, 2, sink.SpanCount())

		// Shutdown
		require.NoError(t, tp.Shutdown(ctx))
	})
}

// TestConfigValidationBothImplementations tests config validation for both implementations
func TestConfigValidationBothImplementations(t *testing.T) {
	TestWithFeatureGates(t, "BasicValidation", func(t *testing.T, useExporterHelper bool) {
		cfg := &Config{
			SendBatchSize:    100,
			SendBatchMaxSize: 1000,
			Timeout:          5 * time.Second,
		}

		requireImplementation(t, cfg, useExporterHelper)
		assert.NoError(t, cfg.Validate())
	})

	TestWithFeatureGates(t, "InvalidBatchSize", func(t *testing.T, useExporterHelper bool) {
		cfg := &Config{
			SendBatchSize:    1000,
			SendBatchMaxSize: 100, // Invalid: max < min
		}

		requireImplementation(t, cfg, useExporterHelper)
		assert.Error(t, cfg.Validate())
	})

	TestWithFeatureGates(t, "InvalidTimeout", func(t *testing.T, useExporterHelper bool) {
		cfg := &Config{
			Timeout: -time.Second, // Invalid: negative timeout
		}

		requireImplementation(t, cfg, useExporterHelper)
		assert.Error(t, cfg.Validate())
	})
}

// TestMetadataKeysValidation tests metadata_keys validation across implementations
func TestMetadataKeysValidation(t *testing.T) {
	TestWithFeatureGates(t, "MetadataKeysSupport", func(t *testing.T, useExporterHelper bool) {
		cfg := &Config{
			MetadataKeys: []string{"key1", "key2"},
		}

		requireImplementation(t, cfg, useExporterHelper)

		err := cfg.Validate()
		if useExporterHelper {
			// Should be rejected in new implementation
			assert.Error(t, err)
			assert.Contains(t, err.Error(), "metadata_keys is not yet supported")
		} else {
			// Should be allowed in legacy implementation
			assert.NoError(t, err)
		}
	})

	TestWithFeatureGates(t, "EmptyMetadataKeys", func(t *testing.T, useExporterHelper bool) {
		cfg := &Config{
			MetadataKeys: []string{}, // Empty should always be allowed
		}

		requireImplementation(t, cfg, useExporterHelper)
		assert.NoError(t, cfg.Validate())
	})
}

// TestFactoryCreationBothImplementations tests factory methods with both implementations
func TestFactoryCreationBothImplementations(t *testing.T) {
	TestWithFeatureGates(t, "AllProcessorTypes", func(t *testing.T, useExporterHelper bool) {
		factory := NewFactory()
		cfg := factory.CreateDefaultConfig().(*Config)

		requireImplementation(t, cfg, useExporterHelper)

		ctx := context.Background()
		creationSet := processortest.NewNopSettings(factory.Type())

		// Test traces processor
		tp, err := factory.CreateTraces(ctx, creationSet, cfg, consumertest.NewNop())
		require.NoError(t, err)
		require.NotNil(t, tp)
		require.NoError(t, tp.Shutdown(ctx))

		// Test metrics processor
		mp, err := factory.CreateMetrics(ctx, creationSet, cfg, consumertest.NewNop())
		require.NoError(t, err)
		require.NotNil(t, mp)
		require.NoError(t, mp.Shutdown(ctx))

		// Test logs processor
		lp, err := factory.CreateLogs(ctx, creationSet, cfg, consumertest.NewNop())
		require.NoError(t, err)
		require.NotNil(t, lp)
		require.NoError(t, lp.Shutdown(ctx))
	})
}

// TestDataProcessingBothImplementations tests actual data processing with both implementations
func TestDataProcessingBothImplementations(t *testing.T) {
	TestWithFeatureGates(t, "BatchingBehavior", func(t *testing.T, useExporterHelper bool) {
		factory := NewFactory()
		cfg := &Config{
			SendBatchSize: 2, // Small batch size for testing
			Timeout:       100 * time.Millisecond,
		}

		requireImplementation(t, cfg, useExporterHelper)

		ctx := context.Background()
		creationSet := processortest.NewNopSettings(factory.Type())
		sink := &consumertest.TracesSink{}

		tp, err := factory.CreateTraces(ctx, creationSet, cfg, sink)
		require.NoError(t, err)
		require.NoError(t, tp.Start(ctx, componenttest.NewNopHost()))
		defer func() { require.NoError(t, tp.Shutdown(ctx)) }()

		// Send traces one by one
		for i := 0; i < 3; i++ {
			td := testdata.GenerateTraces(1)
			require.NoError(t, tp.ConsumeTraces(ctx, td))
		}

		// Wait for batching
		assert.Eventually(t, func() bool {
			return sink.SpanCount() >= 3
		}, 5*time.Second, 10*time.Millisecond)

		// Verify all spans were processed
		assert.Equal(t, 3, sink.SpanCount())
	})
}
